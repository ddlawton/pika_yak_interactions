/.quarto/
/_site/
*.html

# Output files (regenerated by pipeline)
output/figures/*.png
output/figures/*.pdf
output/diagnostics/*.png
output/*.csv

# Data files (large model objects)
data/models/*.qs

# Test and temporary files
test.R
*.tmp
*.log

# System files
.DS_Store
Thumbs.db

# Archive
archive/
