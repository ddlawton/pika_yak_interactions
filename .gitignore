# R and RStudio
.Rhistory
.RData
.Rproj.user/
*.Rproj
.Rprofile

# renv library (managed by renv.lock)
renv/library/
renv/local/
renv/staging/

# targets cache (except meta/meta for reproducibility)
_targets/objects/
_targets/user/
_targets/meta/meta
_targets/meta/process
